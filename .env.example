# ==== 苍穹外卖 环境变量配置 ====
# 复制此文件为 .env，填入真实值
# cp .env.example .env

# 数据库
SKY_DB_PASSWORD=your_db_password

# 阿里云 OSS 对象存储
SKY_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
SKY_OSS_BUCKET=your_bucket_name
SKY_OSS_KEY=your_access_key_id
SKY_OSS_SECRET=your_access_key_secret

# Redis（无密码则留空）
SKY_REDIS_PASSWORD=

# 微信小程序
SKY_WECHAT_APPID=your_wechat_appid
SKY_WECHAT_SECRET=your_wechat_secret
